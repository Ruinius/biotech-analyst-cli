# pyenv
#   For a library or app, you might want to share your .python-version.
#   It's generally recommended to keep it, but can be ignored.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if lock file contains platform-specific dependencies,
#   it may cause issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains platform-specific dependencies.
#   It's generally recommended to check it into source control.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains platform-specific dependencies.
#   It's generally recommended to check it into source control.
#pdm.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

